generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  trips     Trip[]
  savedPlaces SavedPlace[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  USER
  ADMIN
  SUPPORT
}

model Trip {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  destination    String
  startDate      DateTime
  endDate        DateTime
  numberOfPeople Int
  totalBudget    Decimal   @db.Decimal(12, 2)
  travelStyle    String
  summary        String?
  days           TripDay[]
  budget         Budget?
  expenses       Expense[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

model TripDay {
  id         String     @id @default(cuid())
  tripId     String
  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  dayNumber  Int
  date       DateTime
  activities Activity[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([tripId, dayNumber])
}

model Activity {
  id            String   @id @default(cuid())
  tripDayId     String
  tripDay       TripDay  @relation(fields: [tripDayId], references: [id], onDelete: Cascade)
  time          String
  title         String
  location      String
  description   String?
  category      String
  estimatedCost Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Budget {
  id                 String   @id @default(cuid())
  tripId             String   @unique
  trip               Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  accommodation      Decimal  @default(0) @db.Decimal(12, 2)
  food               Decimal  @default(0) @db.Decimal(12, 2)
  transportation     Decimal  @default(0) @db.Decimal(12, 2)
  activities         Decimal  @default(0) @db.Decimal(12, 2)
  shopping           Decimal  @default(0) @db.Decimal(12, 2)
  emergency          Decimal  @default(0) @db.Decimal(12, 2)
  totalEstimatedCost Decimal  @default(0) @db.Decimal(12, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title       String
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  note        String?
  expenseDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tripId])
}

model SavedPlace {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  category        String
  trendScore      Int
  estimatedBudget Decimal  @db.Decimal(12, 2)
  reason          String
  shortDescription String
  imageHint       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

model AiUsageLog {
  id        String   @id @default(cuid())
  userId    String?
  provider  String
  action    String
  status    String
  model     String?
  error     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([action])
}
